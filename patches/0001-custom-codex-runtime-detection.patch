+def _detect_api_mode_for_url(base_url: str, *, model_name: str = "") -> Optional[str]:
     """Auto-detect api_mode from the resolved base URL.
 
     Direct api.openai.com endpoints need the Responses API for GPT-5.x
     tool calls with reasoning (chat/completions returns 400).
+
+    Some custom OpenAI-compatible gateways expose a Codex/Responses-style
+    path (for example ``.../codex/v1``) without using the api.openai.com
+    hostname. Treat those as Responses endpoints when the selected model is
+    GPT-5/Codex-family.
     """
     normalized = (base_url or "").strip().lower().rstrip("/")
     if "api.openai.com" in normalized and "openrouter" not in normalized:
         return "codex_responses"
+    if _model_prefers_responses_api(model_name) and "/codex" in normalized:
+        return "codex_responses"
     return None
 
 
+def _resolve_api_mode(
+    *,
+    base_url: str,
+    model_name: str = "",
+    configured_mode: Optional[str] = None,
+    default: str = "chat_completions",
+) -> str:
+    """Resolve the effective api_mode for a runtime endpoint.
+
+    Preserve explicit non-chat modes, but upgrade stale ``chat_completions``
+    to ``codex_responses`` when the URL/model combination clearly points to a
+    Responses-compatible Codex endpoint.
+    """
+    detected_mode = _detect_api_mode_for_url(base_url, model_name=model_name)
+    if configured_mode == "chat_completions" and detected_mode == "codex_responses":
+        return detected_mode
+    if configured_mode:
+        return configured_mode
+    return detected_mode or default
+
