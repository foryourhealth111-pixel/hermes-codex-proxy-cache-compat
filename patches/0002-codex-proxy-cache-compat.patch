+                "Hermes will stop sending client cache keys for %s",
+                self.session_id or "unknown",
+                self.base_url or "this endpoint",
+            )
+
+        if (
+            self._responses_prompt_cache_key != previous_key
+            or self._responses_prompt_cache_supported != previous_support
+        ):
