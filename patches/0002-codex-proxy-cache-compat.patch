+    def _reset_responses_prompt_cache_state(self) -> None:
+        self._responses_prompt_cache_key = None
+        self._responses_prompt_cache_supported = None
+        self._responses_prompt_cache_warning_logged = False
+
+    def _hydrate_responses_prompt_cache_state(
+        self,
+        session_row: Optional[Dict[str, Any]],
+    ) -> None:
+        if not isinstance(session_row, dict):
+            return
+
+        stored_key = self._normalize_prompt_cache_key(session_row.get("prompt_cache_key"))
+        if stored_key:
+            self._responses_prompt_cache_key = stored_key
+
+        raw_supported = session_row.get("prompt_cache_supported")
+        if raw_supported in (0, 1, False, True):
+            self._responses_prompt_cache_supported = bool(raw_supported)
+            if self._responses_prompt_cache_supported is False:
+                self._responses_prompt_cache_warning_logged = True
+
+    def _select_responses_prompt_cache_key(self) -> Optional[str]:
+        if self._responses_prompt_cache_supported is False:
+            return None
+        return self._responses_prompt_cache_key or self.session_id
+
+    def _uses_codex_transport_compat_headers(self, base_url: Optional[str] = None) -> bool:
+        """Return True for custom Codex-style Responses gateways that expect
+        Codex transport metadata headers in addition to the JSON payload.
+        """
+        if self.api_mode != "codex_responses":
+            return False
+
+        normalized = (base_url or self.base_url or "").strip().lower()
+        if not normalized or "/codex" not in normalized:
+            return False
+        if "chatgpt.com/backend-api/codex" in normalized:
+            return False
+        if "api.githubcopilot.com" in normalized or "models.github.ai" in normalized:
+            return False
+        if "api.openai.com" in normalized:
+            return False
+        return True
+
+    def _responses_transport_headers(self, session_token: Optional[str]) -> Dict[str, str]:
+        turn_id = f"{self.session_id or 'hermes'}_turn_{uuid.uuid4().hex[:12]}"
+        return _codex_transport_headers(session_token or "", turn_id)
+
+    def _persist_responses_prompt_cache_state(self) -> None:
+        if not self._session_db or not self.session_id:
+            return
+        try:
+            self._session_db.update_prompt_cache_state(
