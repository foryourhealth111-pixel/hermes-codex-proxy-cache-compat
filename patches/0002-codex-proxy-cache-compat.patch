+    def _build_runtime_user_context(self) -> str:
+        """Build ephemeral runtime metadata for the current turn.
+
+        This is injected into the current user message at API-call time only,
+        never persisted to the session DB or frozen into the cached system
+        prompt. Keeping it out of the system prompt preserves a stable cache
+        prefix across fresh sessions while still exposing time/model/session
+        metadata to the model.
+        """
+        context_lines = []
+
+        try:
+            from hermes_time import now as _hermes_now
+            _now = _hermes_now()
+            context_lines.append(
+                f"Current date & time: {_now.strftime('%A, %B %d, %Y %I:%M %p')}"
+            )
+        except Exception:
+            pass
+
+        if self.pass_session_id and self.session_id:
+            context_lines.append(f"Session ID: {self.session_id}")
+        if self.model:
+            context_lines.append(f"Model: {self.model}")
+        if self.provider:
+            context_lines.append(f"Provider: {self.provider}")
+
+        if not context_lines:
+            return ""
+
+        return (
+            "<runtime-context>\n"
+            "[System note: The following is Hermes runtime metadata, "
+            "NOT new user input. Use it as execution context only.]\n\n"
+            + "\n".join(context_lines)
+            + "\n"
+            "</runtime-context>"
+        )
