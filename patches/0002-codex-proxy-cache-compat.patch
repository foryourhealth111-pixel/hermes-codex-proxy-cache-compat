+def _codex_transport_headers(session_token: str, turn_id: str) -> dict:
+    """Return Codex-compatible transport headers for custom /codex proxies.
+
+    Some Codex-flavoured gateways, including the user's right.codes route,
+    key prompt-cache behavior off request transport metadata in addition to
+    the JSON body.  These headers intentionally mirror the minimal subset
+    required to unlock prompt-cache compatibility on those gateways.
+    """
+    session_token = str(session_token or "").strip()
+    turn_id = str(turn_id or "").strip()
+    if not session_token:
+        return {
+            "User-Agent": _CODEX_TRANSPORT_USER_AGENT,
+            "originator": "codex_exec",
+        }
+
+    metadata = {
+        "session_id": session_token,
+        "turn_id": turn_id or f"{session_token}_turn",
+        "sandbox": "none",
+    }
+    return {
+        "User-Agent": _CODEX_TRANSPORT_USER_AGENT,
+        "originator": "codex_exec",
+        "session_id": session_token,
+        "x-client-request-id": session_token,
+        "x-codex-window-id": f"{session_token}:0",
+        "x-codex-turn-metadata": json.dumps(metadata, ensure_ascii=False),
+    }
+
